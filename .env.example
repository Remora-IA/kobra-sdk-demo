# Kobra SDK — configuración
# Copiá este archivo a .env y completá los valores que te dio el equipo de Kobra.

KOBRA_API_KEY=reemplazar-con-tu-key
KOBRA_BASE_URL=https://kobra.remora-ia.com

# Para pruebas locales — tu sistema receptor de webhooks
# En producción: la URL pública de tu sistema
WEBHOOK_LOCAL_PORT=8000
