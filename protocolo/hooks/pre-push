#!/usr/bin/env bash
# Pre-push hook — bloquea operaciones destructivas sobre main.
# Activar una vez por clone:  git config core.hooksPath .githooks
#
# Reglas (post-simplificación 2026-05-31):
#   1. Push directo a main: PERMITIDO. Ver COLLABORATION.md Regla 1.
#   2. Nunca force-push (--force, --force-with-lease) a main.
#   3. Nunca borrar main desde remote.

protected_branch="main"
remote="$1"

# stdin: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read local_ref local_sha remote_ref remote_sha; do
  # remote_ref viene como refs/heads/main
  if [[ "$remote_ref" == "refs/heads/$protected_branch" ]]; then

    # Caso 1: borrado de main (local_sha = 0000...)
    if [[ "$local_sha" =~ ^0+$ ]]; then
      echo "ERROR: bloqueado intento de borrar '$protected_branch' en $remote." >&2
      echo "Ver COLLABORATION.md Regla 0." >&2
      exit 1
    fi

    # Push directo a main: PERMITIDO (ver COLLABORATION.md Regla 1).
    # Sigue bloqueado: force-push y delete.

    # Caso 2: force-push detectado (remote tiene commits que local no tiene)
    if [[ ! "$remote_sha" =~ ^0+$ ]]; then
      if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
        echo "ERROR: bloqueado force-push a '$protected_branch'." >&2
        echo "El remote tiene commits que tu local no tiene. Hacé 'git pull' y resolvé." >&2
        echo "NUNCA usar --force sobre main. Ver COLLABORATION.md Regla 0." >&2
        exit 1
      fi
    fi
  fi
done

exit 0
